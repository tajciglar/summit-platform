# Next.js Frontend Environment Variables

# Laravel API
# The URL of the Laravel backend API server
NEXT_PUBLIC_LARAVEL_API_URL=http://localhost:8000

# Internal API authentication token (must match INTERNAL_API_TOKEN in Laravel .env)
INTERNAL_API_TOKEN=any-random-string

# AI / ML Services
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_DESIGN_MODEL=gemini-2.5-flash

# Funnel Checkout
# The URL where customers are redirected to complete checkout
# Example: https://althea-academy.com/checkout/vip-pass
NEXT_PUBLIC_FUNNELKIT_CHECKOUT_URL=
