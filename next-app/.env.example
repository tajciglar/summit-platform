# Next.js Frontend Environment Variables
# -----------------------------------------------------------------------------
# Vars prefixed with NEXT_PUBLIC_ are inlined into the client bundle and visible
# in the browser. Vars without the prefix are server-only. Keep secrets on the
# server-only side.

# -----------------------------------------------------------------------------
# Laravel API
# -----------------------------------------------------------------------------
# Browser-visible Laravel URL used by client components (optin form POST).
NEXT_PUBLIC_LARAVEL_API_URL=http://localhost:8000

# Server-only Laravel URL used by Server Components + API route handlers.
# In most environments this points at the same host as the public one, but
# splitting them lets you route server→Laravel traffic over a private network.
LARAVEL_API_URL=http://localhost:8000

# Shared secret between Laravel and Next.js. MUST match INTERNAL_API_TOKEN
# in Laravel's .env. Server-only — never expose to the browser.
INTERNAL_API_TOKEN=any-random-string

# -----------------------------------------------------------------------------
# AI / ML Services (server-only)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model overrides used by the block generation + polish pipelines.
# See next-app/src/lib/blocks/ for which stage uses which model.
CLAUDE_CODER_MODEL=claude-sonnet-4-20250514
CLAUDE_POLISH_MODEL=claude-sonnet-4-20250514

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_DESIGN_MODEL=gemini-2.5-pro
GEMINI_VISION_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# -----------------------------------------------------------------------------
# Funnel Checkout
# -----------------------------------------------------------------------------
# WordPress/FunnelKit checkout URL used by block CTAs via useCheckoutUrl().
# Per-funnel override: set wp_checkout_redirect_url on the Funnel in Filament.
# Example: https://althea-academy.com/checkout/vip-pass
NEXT_PUBLIC_FUNNELKIT_CHECKOUT_URL=
