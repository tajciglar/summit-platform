{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "A purchasable product offered through a funnel"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "summitSite": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::summit-site.summit-site"
    },
    "type": {
      "type": "enumeration",
      "enum": ["one_time", "subscription", "bundle"],
      "required": true
    },
    "price": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "currency": {
      "type": "string",
      "required": true,
      "default": "eur"
    },
    "stripeProductId": {
      "type": "string"
    },
    "stripePriceId": {
      "type": "string"
    },
    "billingInterval": {
      "type": "enumeration",
      "enum": ["monthly", "yearly"]
    },
    "trialDays": {
      "type": "integer",
      "min": 0
    },
    "files": {
      "type": "json"
    },
    "acTag": {
      "type": "string"
    },
    "acProductTag": {
      "type": "string"
    }
  }
}
