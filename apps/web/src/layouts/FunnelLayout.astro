---
/**
 * FunnelLayout.astro
 *
 * Minimal chrome layout for funnel pages.
 * Intentionally omits navigation and footer — standard conversion funnel UX.
 * Optionally renders a slim progress bar at the top when showProgress is true.
 */

import BaseLayout from './BaseLayout.astro'
import type { SummitSite } from '@summit/types'

export interface Props {
  summit: SummitSite
  seo?: {
    title?: string | null
    description?: string | null
    noindex?: boolean
  }
  stepType?: string
  /** Show a slim progress indicator at the top of the page. */
  showProgress?: boolean
  /** Current step index (1-based). */
  currentStep?: number
  /** Total number of steps in this funnel. */
  totalSteps?: number
}

const {
  summit,
  seo,
  stepType,
  showProgress = false,
  currentStep = 1,
  totalSteps = 1,
} = Astro.props

// Calculate progress percentage — clamp to [0, 100]
const progressPct = totalSteps > 0
  ? Math.min(100, Math.max(0, Math.round((currentStep / totalSteps) * 100)))
  : 0
---

<BaseLayout summit={summit} seo={seo} stepType={stepType}>
  {showProgress && (
    <div
      class="funnel-progress-track"
      role="progressbar"
      aria-valuenow={currentStep}
      aria-valuemin={1}
      aria-valuemax={totalSteps}
      aria-label={`Step ${currentStep} of ${totalSteps}`}
    >
      <div
        class="funnel-progress-bar"
        style={`width: ${progressPct}%`}
      ></div>
    </div>
  )}

  <slot />
</BaseLayout>

<style>
  .funnel-progress-track {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background-color: var(--color-gray-200, #e5e7eb);
    z-index: 1000;
  }

  .funnel-progress-bar {
    height: 100%;
    background-color: var(--color-primary, #3b82f6);
    transition: width 0.4s ease;
    border-radius: 0 2px 2px 0;
  }
</style>
