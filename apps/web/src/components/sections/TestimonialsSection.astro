---
import { Image } from 'astro:assets'
import type { TestimonialsSection } from '@summit/types'

type Props = TestimonialsSection & { class?: string }

const { heading, items, class: className } = Astro.props

function renderStars(rating: number): string {
  const clamped = Math.min(5, Math.max(1, Math.round(rating)))
  return '★'.repeat(clamped) + '☆'.repeat(5 - clamped)
}
---

<section
  data-section="testimonials"
  class:list={['testimonials-section', 'section', className]}
>
  <div class="testimonials-section__container container">
    {heading && (
      <h2 class="testimonials-section__heading">{heading}</h2>
    )}

    <div class="testimonials-section__grid">
      {items.map((item) => (
        <article class="testimonials-section__card">
          {item.rating != null && (
            <div
              class="stars testimonials-section__stars"
              role="img"
              aria-label={`${Math.round(item.rating)} out of 5 stars`}
            >
              {renderStars(item.rating)}
            </div>
          )}

          <blockquote class="testimonials-section__quote">
            <p>"{item.quote}"</p>
          </blockquote>

          <footer class="testimonials-section__author">
            {item.avatar && (
              <div class="testimonials-section__avatar-wrap">
                <Image
                  src={item.avatar.url}
                  alt={item.avatar.alternativeText ?? item.author}
                  width={48}
                  height={48}
                  loading="lazy"
                  class="testimonials-section__avatar"
                  inferSize={false}
                />
              </div>
            )}
            <div class="testimonials-section__author-info">
              <cite class="testimonials-section__author-name">{item.author}</cite>
              {item.role && (
                <span class="testimonials-section__author-role">{item.role}</span>
              )}
            </div>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    width: 100%;
  }

  .testimonials-section__container {
    display: flex;
    flex-direction: column;
    gap: var(--space-12, 3rem);
    align-items: center;
  }

  /* ── Heading ─────────────────────────────────────── */
  .testimonials-section__heading {
    font-family: var(--font-heading, inherit);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    margin: 0;
    color: inherit;
  }

  /* ── Grid ────────────────────────────────────────── */
  .testimonials-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6, 1.5rem);
    width: 100%;
  }

  @media (min-width: 640px) {
    .testimonials-section__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .testimonials-section__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Card ────────────────────────────────────────── */
  .testimonials-section__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4, 1rem);
    padding: var(--space-6, 1.5rem);
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 0.75rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  /* ── Stars ───────────────────────────────────────── */
  .testimonials-section__stars {
    font-size: 1.125rem;
    letter-spacing: 0.05em;
    color: #f59e0b;
  }

  /* ── Quote ───────────────────────────────────────── */
  .testimonials-section__quote {
    margin: 0;
    flex: 1 1 auto;
  }

  .testimonials-section__quote p {
    font-family: var(--font-body, inherit);
    font-size: 0.9375rem;
    line-height: 1.7;
    margin: 0;
    font-style: italic;
    color: inherit;
    opacity: 0.85;
  }

  /* ── Author ──────────────────────────────────────── */
  .testimonials-section__author {
    display: flex;
    align-items: center;
    gap: var(--space-3, 0.75rem);
    padding-top: var(--space-4, 1rem);
    border-top: 1px solid rgba(0, 0, 0, 0.07);
    font-style: normal;
  }

  .testimonials-section__avatar-wrap {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    overflow: hidden;
  }

  .testimonials-section__avatar {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonials-section__author-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .testimonials-section__author-name {
    font-family: var(--font-body, inherit);
    font-size: 0.9375rem;
    font-weight: 700;
    color: inherit;
    font-style: normal;
  }

  .testimonials-section__author-role {
    font-family: var(--font-body, inherit);
    font-size: 0.8125rem;
    opacity: 0.6;
    color: inherit;
  }
</style>
