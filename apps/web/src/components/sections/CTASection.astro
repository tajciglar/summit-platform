---
import type { CTASection } from '@summit/types'

type Props = CTASection & { class?: string }

const {
  heading,
  subheading,
  buttonText,
  buttonUrl,
  layout = 'centered',
  class: className,
} = Astro.props
---

<section
  data-section="cta"
  data-layout={layout}
  class:list={['cta-section', `cta-section--${layout}`, 'section', className]}
>
  <div class="cta-section__container container">
    <div class="cta-section__inner">
      <h2 class="cta-section__heading">{heading}</h2>

      {subheading && (
        <p class="cta-section__subheading">{subheading}</p>
      )}

      {buttonText && buttonUrl && (
        <a href={buttonUrl} class="cta-section__button">
          {buttonText}
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-section {
    width: 100%;
    background: color-mix(in srgb, var(--color-primary, #7c3aed) 5%, #f8f8fc);
  }

  .cta-section__container {
    width: 100%;
  }

  /* ── Inner content wrapper ───────────────────────── */
  .cta-section__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4, 1rem);
    padding: var(--space-12, 3rem) var(--space-8, 2rem);
    border-radius: 1rem;
    background: #ffffff;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  /* ── Centered layout ─────────────────────────────── */
  .cta-section--centered .cta-section__inner {
    align-items: center;
    text-align: center;
    max-width: 44rem;
    margin-inline: auto;
  }

  /* ── Left layout ─────────────────────────────────── */
  .cta-section--left .cta-section__inner {
    align-items: flex-start;
    text-align: left;
  }

  /* ── Right layout ────────────────────────────────── */
  .cta-section--right .cta-section__inner {
    align-items: flex-end;
    text-align: right;
  }

  /* ── Typography ──────────────────────────────────── */
  .cta-section__heading {
    font-family: var(--font-heading, inherit);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
    color: inherit;
  }

  .cta-section__subheading {
    font-family: var(--font-body, inherit);
    font-size: clamp(0.9375rem, 1.5vw, 1.125rem);
    line-height: 1.65;
    margin: 0;
    opacity: 0.75;
    color: inherit;
    max-width: 38rem;
  }

  /* ── Button ──────────────────────────────────────── */
  .cta-section__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary, #7c3aed);
    color: #ffffff;
    font-family: var(--font-body, inherit);
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1;
    padding: 0.875rem 2rem;
    border-radius: 0.375rem;
    text-decoration: none;
    margin-top: var(--space-2, 0.5rem);
    transition: opacity 0.15s ease, transform 0.1s ease;
  }

  .cta-section__button:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .cta-section__button:active {
    transform: translateY(0);
  }
</style>
