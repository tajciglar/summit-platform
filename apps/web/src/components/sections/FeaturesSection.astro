---
import type { FeaturesSection } from '@summit/types'

type Props = FeaturesSection & { class?: string }

const { heading, items, class: className } = Astro.props
---

<section
  data-section="features"
  class:list={['features-section', 'section', className]}
>
  <div class="features-section__container container">
    {heading && (
      <h2 class="features-section__heading">{heading}</h2>
    )}

    <div class="features-section__grid">
      {items.map((item) => (
        <div class="features-section__card">
          {item.icon && (
            <div class="features-section__icon" aria-hidden="true">
              {item.icon}
            </div>
          )}
          <h3 class="features-section__title">{item.title}</h3>
          {item.description && (
            <p class="features-section__description">{item.description}</p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    width: 100%;
  }

  .features-section__container {
    display: flex;
    flex-direction: column;
    gap: var(--space-12, 3rem);
    align-items: center;
  }

  /* ── Section heading ─────────────────────────────── */
  .features-section__heading {
    font-family: var(--font-heading, inherit);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    margin: 0;
    color: inherit;
  }

  /* ── Responsive grid ─────────────────────────────── */
  .features-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6, 1.5rem);
    width: 100%;
  }

  @media (min-width: 640px) {
    .features-section__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-section__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Feature card ────────────────────────────────── */
  .features-section__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 0.75rem);
    padding: var(--space-6, 1.5rem);
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 0.75rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.2s ease, transform 0.15s ease;
  }

  .features-section__card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  /* ── Icon ────────────────────────────────────────── */
  .features-section__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    font-size: 1.75rem;
    line-height: 1;
    background: color-mix(in srgb, var(--color-primary, #7c3aed) 10%, transparent);
    border-radius: 0.5rem;
    flex-shrink: 0;
  }

  /* ── Card text ───────────────────────────────────── */
  .features-section__title {
    font-family: var(--font-heading, inherit);
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    color: inherit;
  }

  .features-section__description {
    font-family: var(--font-body, inherit);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
    opacity: 0.75;
    color: inherit;
  }
</style>
