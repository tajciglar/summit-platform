---
/**
 * 404 — Page not found.
 *
 * Rendered when a funnel slug, step slug, or domain cannot be resolved.
 * Uses a bare HTML structure (no CMS data needed) to avoid cascading errors.
 */
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page not found</title>
    <meta name="robots" content="noindex" />
    <style>
      :root {
        --color-primary: #3b82f6;
        --font-body: 'Inter', system-ui, sans-serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: var(--font-body);
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f9fafb;
        color: #111827;
      }
      .container {
        text-align: center;
        padding: 2rem;
        max-width: 480px;
      }
      h1 { font-size: 5rem; font-weight: 800; color: var(--color-primary); line-height: 1; }
      h2 { font-size: 1.5rem; font-weight: 700; margin-top: 1rem; }
      p { color: #6b7280; margin-top: 0.75rem; }
      a {
        display: inline-block;
        margin-top: 2rem;
        padding: 0.75rem 1.5rem;
        background: var(--color-primary);
        color: #fff;
        text-decoration: none;
        border-radius: 0.5rem;
        font-weight: 600;
        transition: opacity 150ms ease;
      }
      a:hover { opacity: 0.85; }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>404</h1>
      <h2>Page not found</h2>
      <p>The page you're looking for doesn't exist or may have moved.</p>
      <a href="/">Back to home</a>
    </div>
  </body>
</html>
